{
    "compilerOptions": {
        "target": "ESNext",
        "module": "CommonJS",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "baseUrl": ".",
        "outDir": "./dist",
        "rootDirs": [
            "."
        ],
        "paths": {
            "@big-summary-monorepo/trpc": [
                "../../packages/trpc/src/index.ts"
            ],
            "@big-summary-monorepo/db-postgres": [
                "../../packages/database/postgres/index.ts"
            ],
            // "@big-summary-monorepo/db-mssql": [
            //     "../../packages/database/mssql/index.ts"
            // ]
        }
    },
    "include": [
        "src/**/*",
        "../../packages/*/src/**/*", // Добавляем исходники пакетов
        "../../packages/database/*/index.ts", // И индексы баз данных
        "../database/*/generated/client/**/*"
    ]
}