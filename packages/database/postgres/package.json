{
  "name": "@big-summary-monorepo/db-postgres",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build:package": "tsc && shx cp -r generated dist/ && shx rm dist/generated/client/package.json",
    "db:generate": "dotenv -e ../../../.env.development -- prisma generate",
    "db:push": "dotenv -e ../../../.env.development -- prisma db push",
    "migrate:dev": "dotenv -e ../../../.env.development -- prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy && pnpm db:generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^6.19.3",
    "shx": "^0.4.0",
    "tsup": "^8.0.0"
  }
}