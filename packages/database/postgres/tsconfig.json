{
    "compilerOptions": {
        "target": "ESNext",
        "module": "CommonJS",
        "moduleResolution": "node",
        "lib": [
            "ESNext"
        ],
        "rootDir": ".",
        "outDir": "./dist",
        "declaration": true,
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "index.ts",
        "generated/client/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}