{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "es2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "experimentalDecorators": true, // Разрешить декораторы (уберет ошибки @ApiProperty)
    "emitDecoratorMetadata": true, // Важно для корректной работы метаданных
    "noEmit": true
  },
  "include": [
    "vite.config.ts"
  ]
}