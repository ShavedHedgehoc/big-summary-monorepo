{
  "$schema": "https://unpkg.com",
  "workspaces": {
    ".": {},
    "apps/public_api": {
      "entry": ["src/main.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["pg", "pg-hstore"]
    },
    "apps/api": {
      "entry": ["src/main.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": [
        "pg",
        "pg-hstore",
        "mssql",
        "@sequelize/mssql",
        "swagger-ui-express",
        "@types/sequelize"
      ]
    }
  }
}
